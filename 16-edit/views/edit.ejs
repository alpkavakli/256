<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        fieldset {
            width: max-content;
            margin: 30px auto;
        }
    </style>
</head>
<body>
    <form action="/edit/<%= std.id %>" method="post">
        <fieldset>
            <legend>Student Infoo
                <table>
                    <tr>
                        <td>Name:</td>
                        <td>
                            <input type="text" value="<%= std.name %>" name="name" >
                        </td>
                    </tr>
                    <tr>
                        <td>Lastname:</td>
                        <td>
                            <input type="text" value="<%= std.lastname %>" name="lastname" >
                        </td>
                    </tr>
                    <tr>
                        <td>CGPA:</td>
                        <td>
                            <input type="text" value="<%= std.cgpa %>" name="cgpa" >
                        </td>
                    </tr>
                    <tr>
                        <td>Birthday:</td>
                        <td>
                            <input type="date" value="<%= std.bday %>" name="bday" >
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">
                            <button>Save</button>
                        </td>
                    </tr>
                </table>
            </legend>
        </fieldset>
    </form>
</body>
</html>